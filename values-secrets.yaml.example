# ARCL CMP Helm Values - Secrets Configuration
# Copy this file to values-secrets.yaml and fill in your credentials
# NEVER commit values-secrets.yaml to git!

secrets:
  openstack:
    authUrl: "http://your-openstack-server:5000/v3"
    username: "your-openstack-username"
    password: "your-openstack-password"
    projectName: "your-project-name"

  aws:
    accessKeyId: "your-aws-access-key-id"
    secretAccessKey: "your-aws-secret-access-key"

# Ingress configuration
ingress:
  enabled: true
  className: "traefik"  # or "nginx" depending on your cluster
  annotations:
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
  hosts:
    - host: arcl-cmp.yourdomain.com  # Change to your domain
      paths:
        - path: /api
          pathType: Prefix
          service: backend
        - path: /
          pathType: Prefix
          service: frontend
  tls:
    - secretName: arcl-cmp-tls
      hosts:
        - arcl-cmp.yourdomain.com  # Change to your domain

# Frontend configuration
frontend:
  apiUrl: "https://arcl-cmp.yourdomain.com/api"

# Optional: Override default values
