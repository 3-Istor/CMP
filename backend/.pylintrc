[MASTER]
# Use multiple processes to speed up Pylint
jobs=1

[MESSAGES CONTROL]
# Disable specific warnings that are too strict for this project
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    broad-exception-caught,
    import-outside-toplevel,
    unused-argument,
    redefined-outer-name,
    protected-access,
    duplicate-code,
    global-statement,
    unused-import,
    # Modern Python style - f-strings without interpolation are OK
    f-string-without-interpolation,
    # Logging with f-strings is more readable
    logging-fstring-interpolation,
    # Sometimes we have complex functions that need many arguments
    too-many-arguments,
    too-many-positional-arguments,
    # Some functions are naturally complex
    too-many-branches,
    too-many-statements,
    too-many-locals,
    too-many-nested-blocks,
    # Style preferences
    no-else-return,
    # Exception chaining is not always necessary
    raise-missing-from,
    # Sometimes reimports are acceptable
    reimported,
    # Import ordering - handled by isort
    wrong-import-position,
    wrong-import-order,
    ungrouped-imports

[FORMAT]
# Maximum number of characters on a single line (modern standard)
max-line-length=120

[DESIGN]
# Maximum number of locals for function / method body
max-locals=25

[BASIC]
# Good variable names which should always be accepted
good-names=i,j,k,ex,Run,_,id,db,app

[SIMILARITIES]
# Minimum lines number of a similarity
min-similarity-lines=10
