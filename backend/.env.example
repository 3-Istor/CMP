# App Configuration
APP_NAME=CMP API
DEBUG=true  # Set to true for local development (enables mock user fallback)

# OpenStack credentials (required for deployments)
OS_AUTH_URL=http://localhost:5000/v3
OS_USERNAME=arcl-cmp
OS_PASSWORD=your_openstack_password
OS_PROJECT_NAME=3-istor-cloud
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_ENDPOINT_TYPE='internalURL'

# AWS Credentials (for monitoring and deployments)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=eu-west-3

# User Avatars S3 Storage (self-managed S3-compatible storage)
# This is separate from AWS and uses your own S3-compatible service
AVATARS_S3_ENDPOINT=https://s3.3istor.com
AVATARS_S3_BUCKET=user-avatars
AVATARS_S3_ACCESS_KEY_ID=your_avatars_s3_access_key
AVATARS_S3_SECRET_ACCESS_KEY=your_avatars_s3_secret_key
AVATARS_S3_REGION=eu-west-3
AVATARS_PUBLIC_URL_BASE=https://avatars-s3.3istor.com

# Keycloak (for user profile management and project group resolution)
KEYCLOAK_URL=https://auth.3istor.com
KEYCLOAK_CLIENT_ID=3-istor-openid
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret
# Admin credentials used by Terraform k3s-project-bootstrap module
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password

# Vault (for secret management in Terraform modules)
VAULT_URL=https://vault.3istor.com
VAULT_TOKEN=your_vault_token

# Cloudflare (for dynamic DNS in Terraform templates - injected automatically)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# Discord Alerting (optional - for health monitoring alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# GitHub App Integration (for Kubernetes GitOps provisioning)
# Generate the private key from: https://github.com/settings/apps/cnp-portal
# Store the entire PEM content (including BEGIN/END lines) as a single line with \n for newlines
# Example: GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=""
GITHUB_INSTALLATION_ID=""

# S3 Backend for Terraform State (optional - separate AWS account)
# Leave TF_BACKEND_S3_ENABLED=false to use local state files
TF_BACKEND_S3_ENABLED=false
TF_BACKEND_AWS_ACCESS_KEY_ID=your_s3_backend_key
TF_BACKEND_AWS_SECRET_ACCESS_KEY=your_s3_backend_secret
TF_BACKEND_AWS_REGION=eu-west-3
TF_BACKEND_S3_BUCKET=your-terraform-state-bucket
TF_BACKEND_S3_KEY_PREFIX=deployments/
# TF_BACKEND_S3_DYNAMODB_TABLE=terraform-state-lock  # Optional: uncomment for state locking
